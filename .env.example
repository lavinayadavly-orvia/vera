# OpenAI Configuration (REQUIRED)
# Get your API key from https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Delivery Providers
VITE_DESIGN_PROVIDER=native
VITE_DOCUMENT_PROVIDER=native
VITE_PRESENTATION_PROVIDER=native
VITE_AUDIO_PROVIDER=openai
DESIGN_PROVIDER=native
DOCUMENT_PROVIDER=native
PRESENTATION_PROVIDER=native
AUDIO_PROVIDER=openai

# External Provider Keys (Optional)
PLUS_AI_API_KEY=
PLUS_AI_API_BASE_URL=https://api.plusdocs.com/r/v0
PLUS_AI_TEMPLATE_ID=
PLUS_AI_LANGUAGE=en
PLUS_AI_TEXT_HANDLING=PRESERVE
PLUS_AI_POLL_INTERVAL_MS=5000
PLUS_AI_TIMEOUT_MS=300000
PLUS_AI_INCLUDE_USER_TIPS=false
GAMMA_API_KEY=
GAMMA_BASE_URL=https://public-api.gamma.app/v1.0
GAMMA_THEME_ID=
GAMMA_LANGUAGE=en
GAMMA_FOLDER_IDS=
GAMMA_POLL_INTERVAL_MS=5000
GAMMA_TIMEOUT_MS=300000
CANVA_ACCESS_TOKEN=
CANVA_API_BASE_URL=https://api.canva.com/rest/v1
CANVA_INFOGRAPHIC_TEMPLATE_ID=
CANVA_SOCIAL_TEMPLATE_ID=
CANVA_POLL_INTERVAL_MS=4000
CANVA_TIMEOUT_MS=180000

# Platform Runtime
# Set this when you want the React app to journal generations to the local Vera API.
VITE_BACKEND_API_URL=http://127.0.0.1:8787

# Local Vera API
VERA_API_PORT=8787
VERA_STORE_FILE=/absolute/path/to/project/server/data/runtime-store.sqlite

# Video Rendering (Required for final MP4 delivery)
# Server-side settings used by the Vera API
VIDEO_PROVIDER=luma
LUMA_API_KEY=your_luma_api_key_here
LUMA_MODEL=ray-flash-2
LUMA_RESOLUTION=720p
LUMA_SCENE_DURATION=5s
LUMA_POLL_INTERVAL_MS=4000
LUMA_TIMEOUT_MS=240000
# Optional Vite mirrors, only needed if you want the frontend to reflect provider readiness before generation
VITE_VIDEO_PROVIDER=luma
VITE_LUMA_API_KEY=your_luma_api_key_here
VITE_LUMA_MODEL=ray-flash-2
VITE_LUMA_RESOLUTION=720p
VITE_LUMA_SCENE_DURATION=5s
VITE_LUMA_POLL_INTERVAL_MS=4000
VITE_LUMA_TIMEOUT_MS=240000

# ElevenLabs Audio (Optional - for podcast/video narration)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_ENABLE_LOGGING=false
ELEVENLABS_LANGUAGE_CODE=
ELEVENLABS_STABILITY=
ELEVENLABS_SIMILARITY_BOOST=
ELEVENLABS_STYLE=
ELEVENLABS_USE_SPEAKER_BOOST=

# Search Sources
# Tavily is the recommended broad-web search provider for new setups.
# Vera also uses open medical APIs (Europe PMC + ClinicalTrials.gov) and curated
# official sources by default.
TAVILY_API_KEY=your_tavily_api_key_here
VITE_TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_SEARCH_DEPTH=advanced

# Google Custom Search JSON API is closed to new customers as of 2026.
# The Google settings below are legacy/optional.
# If you already have legacy CSE access, use a dedicated key restricted to
# Custom Search JSON API. This avoids conflicts with Gemini-only keys.
GOOGLE_SEARCH_API_KEY=your_google_custom_search_api_key_here
GOOGLE_CX=your_google_cx_here
VITE_GOOGLE_SEARCH_API_KEY=your_google_custom_search_api_key_here
VITE_GOOGLE_CX=your_google_cx_here

# If Google keys are absent or blocked, Vera still captures source candidates
# from open medical APIs and a curated official-source fallback for common topics.
